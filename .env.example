OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=llm-rag
# RAGAS: эмбеддинги для метрики answer relevancy (HuggingFace, см. evaluation/ragas/metrics.py)
# RAGAS_EMBEDDING_MODEL=all-MiniLM-L6-v2

JWT_SECRET=change-me-in-production
JWT_EXPIRES_SECONDS=3600
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5175,http://127.0.0.1:5175
# Опционально: regex для origin в LAN (по умолчанию в коде уже есть 192.168.* и 10.* на портах 3000/5175)
# CORS_ALLOW_ORIGIN_REGEX=

# Embedding model (sentence-transformers compatible)
EMBEDDING_MODEL=ai-sage/Giga-Embeddings-instruct

# Reranking
RERANK_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_FETCH_MULTIPLIER=3

# Telegram (get credentials at https://my.telegram.org — required for real fetch)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=llm_rag_session
# В Docker сессия Telethon хранится в volume (см. docker-compose); первый вход лучше сделать
# с теми же API_ID/HASH локально (telethon), затем перезапустить контейнер — или скопировать .session в volume.
TELEGRAM_MESSAGE_LIMIT=200
TELEGRAM_DAYS_BACK=30
# Если «Connection to Telegram failed»: блокировка/файрвол — VPN на хосте + локальный SOCKS, например:
# TELEGRAM_PROXY=socks5://127.0.0.1:1080
# TELEGRAM_CONNECTION_RETRIES=20
# TELEGRAM_TIMEOUT_SEC=30

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/llm_rag
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Frontend clients
VITE_API_URL=http://localhost:8000/api/v1
# Локальный dev: куда Vite проксирует /api/v1 (в Docker compose задаётся host.docker.internal)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
VITE_RAG_API_URL=http://localhost:8000/api/v1
VITE_PROJECT_ID=1
